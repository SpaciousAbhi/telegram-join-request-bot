# ==========================================
# REQUIRED CONFIGURATION (Heroku Config Vars)
# ==========================================

# Telegram Bot Token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Main Owner's numeric Telegram User ID (e.g. 12345678)
OWNER_ID=YOUR_OWNER_ID_HERE

# MongoDB Connection URI (e.g. mongodb+srv://username:password@cluster.mongodb.net/dbname)
MONGO_DB_URI=YOUR_MONGODB_DATABASE_URL_HERE

# ==========================================
# OPTIONAL CONFIGURATION (Fallback defaults provided)
# ==========================================

# Overrides for Pyrogram MTProto API credentials
# API_ID=
# API_HASH=

# Approval Speed Limit (Requests per minute, default 160)
# DEFAULT_APPROVAL_SPEED=160
