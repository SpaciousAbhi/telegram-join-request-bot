# ==========================================
# REQUIRED CONFIGURATION (Heroku Config Vars)
# ==========================================

# Telegram bot token from @BotFather.
BOT_TOKEN=

# Main owner's numeric Telegram user ID, for example 12345678.
OWNER_ID=

# MongoDB connection URI, for example:
# mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_DB_URI=

# ==========================================
# OPTIONAL CONFIGURATION
# ==========================================

# Dedicated MTProto API credentials from my.telegram.org.
# Shared fallbacks exist in config.py, but production should use your own.
API_ID=
API_HASH=

# Approval speed limit in requests per minute.
DEFAULT_APPROVAL_SPEED=160
